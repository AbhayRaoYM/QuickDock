# QuickDock App — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ── Sidecar connection ────────────────────────────────────────────────────
# These must match the server's QUICKDOCK_HOST / QUICKDOCK_PORT
VITE_API_HOST=127.0.0.1
VITE_API_PORT=3579
VITE_API_BASE_URL=http://127.0.0.1:3579
